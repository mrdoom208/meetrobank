{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",  // ← Point directly to client
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }  // ← Relative to client/
    },
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server.js" },
    { "source": "/(.*)", "destination": "/dist/index.html" }
  ]
}
